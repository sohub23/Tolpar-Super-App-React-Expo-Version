    alignItems: "center",
    justifyContent: "space-between",
    paddingHorizontal: 16,
    marginTop: 16,
    marginBottom: 8,
  },
  seeAll: { color: "#07C160", fontSize: 13, fontWeight: "600" },
  nearbyScrollContent: { paddingHorizontal: 16, gap: 12 },
  bizCard: {
    backgroundColor: "#FFFFFF",
    borderRadius: 14,
    width: 150,
    overflow: "hidden",
    shadowColor: "#000",
    shadowOffset: { width: 0, height: 1 },
    shadowOpacity: 0.06,
    shadowRadius: 4,
    elevation: 2,
  },
  bizImage: {
    height: 80,
    alignItems: "center",
    justifyContent: "center",
  },
  bizImageIcon: {
    width: 40,
    height: 40,
    borderRadius: 20,
    alignItems: "center",
    justifyContent: "center",
  },
  bizInfo: { padding: 10 },
  bizName: { fontSize: 13, fontWeight: "600", color: "#1A1A1A", marginBottom: 4 },
  bizMeta: { flexDirection: "row", marginBottom: 4 },
  bizTag: { borderRadius: 6, paddingHorizontal: 6, paddingVertical: 2 },
  bizTagText: { fontSize: 11, fontWeight: "500" },
  bizRating: { flexDirection: "row", alignItems: "center", gap: 2 },
  bizRatingText: { fontSize: 12, color: "#333", fontWeight: "600" },
