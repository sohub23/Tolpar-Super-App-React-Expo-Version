  dot: { width: 6, height: 6, borderRadius: 3, backgroundColor: "#CCCCCC" },
  dotActive: { width: 18, height: 6, borderRadius: 3, backgroundColor: "#07C160" },
  sectionCard: {
    backgroundColor: "#FFFFFF",
    marginHorizontal: 16,
    borderRadius: 16,
    padding: 16,
    marginTop: 12,
    shadowColor: "#000",
