    marginBottom: 6,
  },
  quickActionLabel: {
    fontSize: 12,
    color: "#333333",
    fontWeight: "500",
    textAlign: "center",
  },
  bannerSection: { marginTop: 12, marginHorizontal: 16 },
  bannerScrollContent: { gap: 12 },
  bannerSlide: {
    width: BANNER_WIDTH,
    borderRadius: 16,
    padding: 20,
    minHeight: 110,
    justifyContent: "center",
  },
  bannerTitle: {
    color: "#FFFFFF",
    fontSize: 22,
    fontWeight: "700",
    marginBottom: 4,
  },
  bannerSubtitle: { color: "rgba(255,255,255,0.85)", fontSize: 13, marginBottom: 12 },
  bannerBtn: {
    backgroundColor: "rgba(255,255,255,0.25)",
    borderRadius: 20,
    paddingHorizontal: 16,
    paddingVertical: 6,
    alignSelf: "flex-start",
    borderWidth: 1,
    borderColor: "rgba(255,255,255,0.4)",
  },
  bannerBtnText: { color: "#FFFFFF", fontSize: 12, fontWeight: "600" },
