# Copy this to .env.local and fill in your credentials

# ========== GOOGLE OAUTH ==========
# Get these from: https://console.cloud.google.com/
# 1. Create a project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials for Web, iOS, and Android
# 4. Replace the values below

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# ========== SUPABASE (Already configured) ==========
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ========== APPLE OAUTH (Optional, if using Apple Server-to-Server OAuth) ==========
# Get these from: https://developer.apple.com/account/
# Only needed if implementing full Apple OAuth (not just Sign in with Apple)

APPLE_SERVICE_ID=com.tolpar.service
APPLE_TEAM_ID=your-team-id
APPLE_KEY_ID=your-key-id

# ========== CATDOES WATCH (Error Tracking) ==========
EXPO_PUBLIC_CATDOES_WATCH_KEY=your-catdoes-watch-key
